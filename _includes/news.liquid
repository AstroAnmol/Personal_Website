<div class="news">
  {% if site.news != blank %}
    {% assign news_size = site.news | size %}
    <div
      class="table-responsive"
      {% if include.limit and site.announcements.scrollable and news_size > 3 %}
        style="max-height: 60vw"
      {% endif %}
    >
      <table class="table table-sm table-borderless">
        {% assign news = site.news | reverse %}
        {% if include.limit and site.announcements.limit %}
          {% assign news_limit = site.announcements.limit %}
        {% else %}
          {% assign news_limit = news_size %}
        {% endif %}
        {% for item in news limit: news_limit %}
          {% assign item_date = item.date | date: "%s" | plus: 0 %}
          {% assign today_date = site.time | date: "%s" | plus: 0 %}
          {% assign days_ago = today_date | minus: item_date | divided_by: 86400 %}
          <tr style="border-bottom: 1px solid rgba(var(--global-theme-color-rgb, 5, 166, 166), 0.1);">
            <th scope="row" style="width: 20%; color: var(--global-theme-color); font-weight: 600;">
              {{ item.date | date: '%b %d, %Y' }}
              {% if days_ago < 30 %}
                <span class="badge" style="background-color: var(--global-theme-color); margin-left: 0.5rem; font-size: 0.75rem;">NEW</span>
              {% endif %}
            </th>
            <td style="padding-left: 1.5rem;">
              {% if item.inline %}
                {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
              {% else %}
                <a class="news-title" href="{{ item.url | relative_url }}" style="color: var(--global-text-color);">{{ item.title }}</a>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>
