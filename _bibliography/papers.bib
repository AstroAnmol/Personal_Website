
@incollection{ranade_survey_2021,
	title = {Survey and {Analysis} of {Payloads} for {Missions} on {PSLV}'s {Orbital} {Platform}},
	url = {https://arc.aiaa.org/doi/abs/10.2514/6.2021-0691},
	abstract = {In this paper, prospects of the utilization of the 4th stage of ISRO’s PSLV, after the completion of the launch mission, as an orbital platform, to host scientific payloads have been discussed. Payloads from 4 domains - Technological Demonstration, Earth Observation, Microgravity, Biology Experiments and the associated mission concepts have been surveyed, and comments have been made on their suitability to be launched onboard the orbital platform. Technological challenges in achieving these have been highlighted. Based on this analysis, two technology demonstration missions have been proposed by the team.},
	booktitle = {{AIAA} {Scitech} 2021 {Forum}},
	author = {Ranade, Aniruddha R. and Sikka, Anmol and Bhansali, Sanskriti and Jagdale, Karan S. and Shrivas, Puneet and Jirwankar, Piyush and Bhattu, Mayuresh and Lall, Aryan and Kurrey, Prashant and Wakode, Ashay and Tiwari, Dhananjay and Parikh, Niket and Banzal, Neilabh and Prathiksh, KT Prajwal and Zacharia, Shaun and Kanabar, Millen and Laddha, Shreya and Savarkar, Atharv V. and Vadladi, Amrutha L. and Dhaka, Mohit and Gupta, Yuktee and Kejriwal, Abhishek and Agrawal, Hrithik and V, Aakash and Shinde, Ritul and Oza, Mitalee and Yadav, Rohit K. and Sabde, Rateesh A. and Bharti, Chinmay and Kasat, Pranav G. and Jeloka, Bhavini and Shah, Rikin},
	year = {2021},
	doi = {10.2514/6.2021-0691},
	note = {\_eprint: https://arc.aiaa.org/doi/pdf/10.2514/6.2021-0691},
}

@inproceedings{jagdale_sanket_2020,
	title = {Sanket - {Technology} {Demonstration} of {Antenna} {Deployment} {System} on {PSLV} {Stage} 4 {Orbital} {Platform}},
	abstract = {An Antenna Deployment System has become an essential component of any pico- or nano-satellite design due to space constraints during launch. The Sanket mission is a technology demonstration designed to be flown on the Indian Space Research Organization’s PSLV Stage-4 Orbital Platform (PS4-OP) [1]. It aims to qualify the team’s Antenna Deployment System (ADS) in Ultra High Frequency (UHF) band to a Technology Readiness Level (TRL)-7 in Low Earth Orbit (LEO). Sanket comprises of an ADS and an Auxiliary system. The purpose of the auxiliary system is to test the ADS on PS4-OP simulating a 1U CubeSat mission life cycle and conditions. Sanket will be mounted on PS4-OP which remains in LEO for around six months. Our Antenna Deployment System is developed as an independent module that is compatible with standard CubeSat sizes 1U, 2U, and 3U.},
	language = {en},
	author = {Jagdale, Karan and Munjal, Mrigi and Kurrey, Prashant and Wakode, Ashay and Lohiya, Pushkar and Shrivas, Puneet and Sikka, Anmol and Bhansali, Sanskriti and Kejriwal, Abhishek and Vadladi, Amrutha Lakshmi and Kumar, Ankit and Agarwal, Hrithik and Dhaka, Mohit and Kasat, Pranav G and Shinde, Ritul and Laddha, Shreya and Yadav, Adesh and Mehta, Akshat},
	year = {2020},
	pages = {4},
	file = {Jagdale et al. - 2020 - Sanket - Technology Demonstration of Antenna Deplo.pdf:C\:\\Users\\anmol\\Zotero\\storage\\DNFC4UKH\\Jagdale et al. - 2020 - Sanket - Technology Demonstration of Antenna Deplo.pdf:application/pdf},
}

