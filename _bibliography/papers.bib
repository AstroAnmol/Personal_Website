
@inproceedings{ranade_learnings_2019,
	address = {India},
	title = {Learnings from {Pratham}, {First} {Student} {Satellite} of {IIT} {Bombay}},
	abstract = {Pratham, IIT Bombay's first student satellite, was launched on 26th September 2016. The satellite was operational, but the mission was only 90\% successful as only the beacon signal was received and not the downlink signal. After launch, an exhaustive analysis was done to identify possible causes of failure, including a review of the whole journey of the Pratham from conceptualization to launch, to identify all the possible improvements at each stage. This paper gives some generic suggestions and tips which can be incorporated throughout different phases of the project to avoid similar mistakes in future missions.},
	author = {Ranade, Aniruddha R. and Sikka, Anmol and Sanghvi, Yash and Chirame, Sanket and Joshi, Anant and Jain, Chaitanya and Shah, Dhrumil and Kuruwa, Anuj and Verma, Shashank and Katla, Virul},
	year = {2019},
	abbr={Conference},
}

@incollection{ranade_survey_2021,
	title = {Survey and {Analysis} of {Payloads} for {Missions} on {PSLV}'s {Orbital} {Platform}},
	url = {https://arc.aiaa.org/doi/abs/10.2514/6.2021-0691},
	abstract = {In this paper, prospects of the utilization of the 4th stage of ISRO’s PSLV, after the completion of the launch mission, as an orbital platform, to host scientific payloads have been discussed. Payloads from 4 domains - Technological Demonstration, Earth Observation, Microgravity, Biology Experiments and the associated mission concepts have been surveyed, and comments have been made on their suitability to be launched onboard the orbital platform. Technological challenges in achieving these have been highlighted. Based on this analysis, two technology demonstration missions have been proposed by the team.},
	booktitle = {{AIAA} {Scitech} 2021 {Forum}},
	author = {Ranade, Aniruddha R. and Sikka, Anmol and Bhansali, Sanskriti and Jagdale, Karan S. and Shrivas, Puneet and Jirwankar, Piyush and Bhattu, Mayuresh and Lall, Aryan and Kurrey, Prashant and Wakode, Ashay and Tiwari, Dhananjay and Parikh, Niket and Banzal, Neilabh and Prathiksh, KT Prajwal and Zacharia, Shaun and Kanabar, Millen and Laddha, Shreya and Savarkar, Atharv V. and Vadladi, Amrutha L. and Dhaka, Mohit and Gupta, Yuktee and Kejriwal, Abhishek and Agrawal, Hrithik and V, Aakash and Shinde, Ritul and Oza, Mitalee and Yadav, Rohit K. and Sabde, Rateesh A. and Bharti, Chinmay and Kasat, Pranav G. and Jeloka, Bhavini and Shah, Rikin},
	doi = {10.2514/6.2021-0691},
	year={2021},
	note = {\_eprint: https://arc.aiaa.org/doi/pdf/10.2514/6.2021-0691},
	abbr={AIAA Scitech},
}

@inproceedings{sanghvi_quality_2020,
	address = {Singapore},
	title = {Quality {Assurance} {Practices} for {Student} {Satellite} {Teams}},
	isbn = {978-981-15-1724-2},
	abstract = {Pratham, IIT Bombay's first student satellite was launched on September 26, 2016 onboard PSLV C-35. The intended mission life was of 4 months. The satellite was operational but the mission was not successful as only beacon signal was received and not the downlink signal. During the post-launch analysis, the team realized the importance of maintaining the quality. The IIT Bombay Student Satellite Team then started working on instituting quality assurance and management practices within the team. In the process, we listed and made few guidelines that can be useful for initiating and managing quality assurance in Student Satellite Projects across the world. This paper talks about our initial analysis and then lists down various activities to be performed to assure quality.},
	booktitle = {Advances in {Small} {Satellite} {Technologies}},
	publisher = {Springer Singapore},
	author = {Sanghvi, Yash and Sikka, Anmol and Ranade, Aniruddha Ravindra},
	editor = {Sastry, PSR Srinivasa and CV, Jiji and Raghavamurthy, D.V.A. and Rao, Samba Siva},
	year = {2020},
	pages = {439--450},
	abbr={Conference},
}
